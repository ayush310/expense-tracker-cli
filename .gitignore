# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables (NEVER commit secrets/API keys)
.env
.env.*
!.env.example

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp

# OS-specific
.DS_Store
Thumbs.db

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Logs and local data
*.log
*.db
*.sqlite3

# Project-specific local data (e.g. your expense tracker's saved data)
expenses.json